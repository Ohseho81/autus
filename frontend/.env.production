# ═══════════════════════════════════════════════════════════════════════════════
# AUTUS Frontend Environment (Production)
# ═══════════════════════════════════════════════════════════════════════════════

# Backend API URL (빈 값 = 같은 도메인의 /api 사용)
VITE_API_URL=

# WebSocket URL (빈 값 = 같은 도메인 사용)
VITE_WS_URL=

# AUTUS Cloud API (autus-ai.com)
VITE_AUTUS_API_URL=https://autus-ai.com

# Supabase
# pphzvnaedmzcvpxjulti (학생 802명 등 atb_* 데이터)
VITE_SUPABASE_URL=https://pphzvnaedmzcvpxjulti.supabase.co
VITE_SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY_FROM_SUPABASE_DASHBOARD

# Debug 비활성화
VITE_DEBUG=false

# ═══════════════════════════════════════════════════════════════════════════════
# MoltBot AI (OpenRouter)
# ═══════════════════════════════════════════════════════════════════════════════

# OpenRouter API Key (Claude 3.5 Sonnet 사용)
# 발급: https://openrouter.ai/keys
# 충전: https://openrouter.ai/credits
VITE_OPENROUTER_API_KEY=

# AI 모델 (기본: anthropic/claude-3.5-sonnet)
# 옵션: anthropic/claude-3-haiku, openai/gpt-4o, google/gemini-pro-1.5
VITE_OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
