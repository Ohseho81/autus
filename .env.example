# ============================================
# 🔧 AUTUS 환경변수 템플릿
# ============================================
# 이 파일을 복사해서 .env 파일을 만드세요:
#   cp .env.example .env
# ============================================

# ============================================
# 1. Supabase 설정
# ============================================
# Supabase (pphzvnaedmzcvpxjulti - 학생 802명 등 atb_* 데이터)
SUPABASE_URL=https://pphzvnaedmzcvpxjulti.supabase.co
SUPABASE_ANON_KEY=paste-from-supabase-dashboard-api
SUPABASE_SERVICE_ROLE_KEY=paste-from-supabase-dashboard-api  # 강사/수업 업로드 시 필요

# Vite용 (KRATON V2 웹앱 / Vercel)
VITE_SUPABASE_URL=https://pphzvnaedmzcvpxjulti.supabase.co
VITE_SUPABASE_ANON_KEY=paste-from-supabase-dashboard-api

# ============================================
# 2. Telegram Bot 설정
# ============================================
# @BotFather에서 생성
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_OWNER_CHAT_ID=123456789

# ============================================
# 3. MoltBot Brain 설정
# ============================================
# 로컬 Brain 서버 (npm start로 실행)
MOLTBOT_BRAIN_URL=http://localhost:3030

# Vite용
VITE_MOLTBOT_BRAIN_URL=http://localhost:3030

# ============================================
# 4. PortOne (결제) 설정 - 선택사항
# ============================================
# PortOne 관리자 콘솔에서 확인
PORTONE_IMP_KEY=imp_xxxxx
PORTONE_IMP_SECRET=xxxxx
PORTONE_API_KEY=xxxxx

# ============================================
# 5. 알림 설정 - 선택사항
# ============================================
# 카카오 알림톡
KAKAO_API_KEY=xxxxx
KAKAO_SENDER_KEY=xxxxx

# Firebase (FCM Push)
FIREBASE_PROJECT_ID=your-project
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ============================================
# 6. Database 설정
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/autus
REDIS_URL=redis://localhost:6379

# ============================================
# 7. OAuth 설정 - 선택사항
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ============================================
# 8. Docker 서비스 인증
# ============================================
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your-secure-password

# ============================================
# 9. 조직 설정
# ============================================
DEFAULT_ORG_ID=your-org-uuid
NEXT_PUBLIC_DEFAULT_ORG_ID=your-org-uuid

# ============================================
# 10. 기타
# ============================================
NODE_ENV=development
PORT=3030
AUTUS_DIR=~/Desktop/autus
