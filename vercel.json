{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "regions": ["icn1"],
  "builds": [
    {"src": "vercel-api/package.json", "use": "@vercel/next"}
  ],
  "crons": [
    {"path": "/api/kakao/worker", "schedule": "*/5 * * * *"},
    {"path": "/api/cron/pre-attendance", "schedule": "*/30 * * * *"},
    {"path": "/api/cron/consultation-trigger", "schedule": "0 9 * * *"},
    {"path": "/api/cron/monthly-report", "schedule": "0 10 28-31 * *"}
  ],
  "routes": [
    {"src": "/api/(.*)", "dest": "vercel-api/api/$1"},
    {"src": "/(.*)", "dest": "vercel-api/$1"}
  ]
}
