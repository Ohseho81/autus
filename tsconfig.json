{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2022"
    ],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": false,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "moltbot-brain/**/*.js",
    "moltbot-bridge/**/*.js",
    "vercel-api/**/*.ts",
    "vercel-api/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "supabase/functions/**/*"
  ]
}