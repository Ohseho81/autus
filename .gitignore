# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# Virtual environments (전역)
**/.venv/
**/venv/
.venv/
venv/

# Archive (legacy code - 로컬 보관용)
_archive/
_archive_*/
_legacy/

# Environment
.env
.env.*
!.env.sample
!.env.example
!.env.*.example

# Database
*.db
*.sqlite
*.sqlite3

# Coverage & Testing
.coverage
htmlcov/
.pytest_cache/
test-results/
playwright-report/

# IDE
.vscode/
.idea/
.cursor/
*.swp
*.swo

# Separate Projects / Submodules (nested git repos)
clawdbot/
kraton-unified/
# kraton-v2/  # 배포에 필요하여 제거

# AI Generated (local only)
ai-generated/
.kraton/

# OS
.DS_Store
Thumbs.db

# Temporary
*.log
*.tmp
*.bak
logs/

# Dev logs (auto-generated)
docs/dev-log/
docs/reports/

# Misc folders (local only)
기타/

# Build outputs
dist/
build/
*.egg-info/

# Next.js build
**/.next/
**/out/

# Vite build
**/dist/

# Node.js (전역)
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Credentials (절대 커밋하지 말 것)
credentials.json
*.pem
*.key
secrets/

# PII Data (학생/결제/회원 데이터 — 절대 커밋하지 말 것)
*.csv
*.xlsx
*.docx
.~lock.*
students_insert.sql

# Expo local state
**/.expo/

# Large files
*.zip
*.tar.gz
*.rar
.vercel

